{
  "name": "aegis-monorepo",
  "version": "1.0.0",
  "description": "Aegis Smart Stadium OS - Phase 1 Foundation",
  "private": true,
  "scripts": {
    "bootstrap": "pnpm install",
    "lint": "cd frontend && npm run lint",
    "lint:fix": "cd frontend && npm run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "test": "npm run test --prefix frontend",
    "test:backend": "cd backend && pytest",
    "test:frontend": "npm run test --prefix frontend",
    "test:playwright": "npm run test --prefix frontend -- --project=playwright",
    "build": "npm run build --prefix frontend",
    "build:backend": "cd backend && pip install -r requirements.txt",
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "start_backend.bat",
    "dev:frontend": "start_frontend.bat",
    "start": "start_all.bat",
    "stop": "stop_all.bat",
    "verify": "python scripts/verify_environment.py",
    "health": "python scripts/health_check.py",
    "clean": "python -c \"import shutil, os; [shutil.rmtree(os.path.join(root, d)) for root, dirs, files in os.walk('.') for d in dirs if d == '__pycache__']\" 2>/dev/null || echo Cleanup complete"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
