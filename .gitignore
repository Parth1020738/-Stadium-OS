# Aegis monorepo root gitignore
node_modules/
node_modules
.venv/
.venv
venv/
env/
env
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
coverage/
htmlcov/
dist/
build/
.next/
out/
.expo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example
!*.env.example
!*.env.local.example

# Databases & logs
*.db
*.sqlite
*.sqlite3
*.db-journal
*.log

# Caches, temporary files and archives
.cache
*.cache
*.tmp
*.zip
Thumbs.db
.DS_Store

# Generated test/browser artifacts
browser_logs/
browser_logs
playwright-report/
playwright-report
test-results/
test-results

# Media & assets (Ignore generated PNG/JPG, allow documentation/design assets)
*.mp4
*.png
*.jpg
!docs/screenshots/*.png
!docs/screenshots/*.jpg
.devcontainer/

# Temporary and clean directories
tmp/
temp/
brain/
scratch/
reports/generated/


