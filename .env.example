# ============================================
# AEGIS SMART STADIUM OS — ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values for your environment.
# ====================================

# --------------------------------------------
# BACKEND CONFIGURATION
# --------------------------------------------
# Environment: development, staging, production
NODE_ENV=development

# Database URL (SQLite for local dev, PostgreSQL for production)
# SQLite example: sqlite+aiosqlite:///./aegis.db
# PostgreSQL example: postgresql+asyncpg://user:pass@localhost:5432/aegis_db
DATABASE_URL=sqlite+aiosqlite:///./aegis.db

# Redis URL (required for session management and token blacklisting)
REDIS_URL=redis://localhost:6379/0

# Kafka Bootstrap Servers (optional - only for production event streaming)
# Leave empty for local development without Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production-use-a-strong-random-string

# Application Secret Key (for encryption, session signing, etc.)
SECRET_KEY=your-application-secret-key-change-this-in-production

# Backend API URL (used by frontend for API calls)
BACKEND_URL=http://localhost:8000

# --------------------------------------------
# FRONTEND CONFIGURATION
# --------------------------------------------
# Next.js Public API URL (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Next.js Public WebSocket URL (for real-time updates)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --------------------------------------------
# AI/ML CONFIGURATION (ALL USE MOCK MODE BY DEFAULT)
# --------------------------------------------
# IMPORTANT: The application works COMPLETELY without these API keys.
# All AI features use realistic mock data when keys are not provided.
# To enable real AI providers, set ENABLE_MOCK_AI=false and provide keys.

# Enable/Disable Mock AI Mode (true = no real API calls, false = use real APIs)
ENABLE_MOCK_AI=true

# AI Provider Selection: mock, gemini, openai, anthropic
AI_PROVIDER=mock

# Google Gemini API Key (optional - get from https://aistudio.google.com/)
GEMINI_API_KEY=MOCK_MODE
GEMINI_MODEL=gemini-2.5-flash
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=2048
TOP_P=0.95
TOP_K=40
AI_TIMEOUT=30
AI_CACHE_TTL=3600
ENABLE_STREAMING=true
ENABLE_AI_CACHE=true
ENABLE_TOKEN_LOGGING=true
ENABLE_COST_TRACKING=true

# OpenAI API Key (optional - get from https://platform.openai.com/)
OPENAI_API_KEY=MOCK_MODE

# Anthropic Claude API Key (optional - get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=MOCK_MODE

# Google OAuth Client ID (optional - for Google Sign-In)
GOOGLE_CLIENT_ID=MOCK_MODE

# --------------------------------------------
# MONITORING & OBSERVABILITY (OPTIONAL)
# --------------------------------------------
# Enable/Disable metrics collection
ENABLE_METRICS=false

# Sentry DSN (optional - for error tracking)
SENTRY_DSN=

# --------------------------------------------
# EXTERNAL SERVICES (OPTIONAL)
# --------------------------------------------
# MinIO Object Storage (for document uploads)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aegis-documents

# Email Service (for notifications)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aegis-stadium.local

# --------------------------------------------
# SECURITY NOTES
# --------------------------------------------
# 1. NEVER commit .env files to version control
# 2. Use strong, random secrets in production (32+ characters)
# 3. Rotate JWT_SECRET and SECRET_KEY periodically
# 4. Use HTTPS in production (set NEXT_PUBLIC_API_URL to https://)
# 5. Enable Redis in production for token blacklisting
# 6. Use PostgreSQL in production (not SQLite)
# 7. Set ENABLE_MOCK_AI=false only when real API keys are configured