# ==============================================================================
# AEGIS SMART STADIUM OS - CORE ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and customize values for your deployment.

# Node environment setting (development / production)
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------------------------
# DATABASE & DATA STORES
# ------------------------------------------------------------------------------
# Connection string for relational database. SQLite is used for local fallback.
# For production PostgreSQL: postgresql://user:password@localhost:5432/aegis
DATABASE_URL=sqlite:///./aegis.db

# Redis instance URL for cache storage, blacklist, and session storage
REDIS_URL=redis://localhost:6379/0

# Kafka messaging brokers bootstrap servers connection list
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_URL=localhost:9092

# ------------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ------------------------------------------------------------------------------
# Secret key used by backend framework for signing sessions
SECRET_KEY=super-secure-app-secret-key-change-this-in-production

# JWT encryption key (must be at least 32 characters long)
JWT_SECRET=super-secure-jwt-secret-key-32-chars-long-or-more

# JWT algorithm setting
JWT_ALGORITHM=HS256

# JWT token lifespan minutes
JWT_EXPIRE_MINUTES=60

# Google OAuth client ID (for SSO authentication integrations)
GOOGLE_CLIENT_ID=placeholder-google-client-id

# ------------------------------------------------------------------------------
# INTEGRATIONS & APIS
# ------------------------------------------------------------------------------
# Main backend server access URL
BACKEND_URL=http://localhost:8000

# Next.js client-facing API endpoint URL (FastAPI backend v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Next.js client-facing WebSocket stream endpoint URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# MinIO/S3 object storage endpoint configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=aegis-storage

# ------------------------------------------------------------------------------
# ARTIFICIAL INTELLIGENCE (AI) PROVIDERS
# ------------------------------------------------------------------------------
# Mock mode toggle to allow the system to function completely without paid keys
ENABLE_MOCK_AI=true
AI_PROVIDER=mock
USE_REAL_GEMINI=false

# Google Gemini API key (set to MOCK_MODE for local development)
GEMINI_API_KEY=MOCK_MODE
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API key (set to MOCK_MODE for local development)
OPENAI_API_KEY=MOCK_MODE

# Anthropic Claude API key (set to MOCK_MODE for local development)
ANTHROPIC_API_KEY=MOCK_MODE
